# ──────────────────────────────────────────────────────────────────────────
# BridgingMinds, environment variables
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored. NEVER commit real keys.
# ──────────────────────────────────────────────────────────────────────────

# Claude (Anthropic): language analysis, feedback, practice plans, debate AI.
# Get a key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# AssemblyAI: speech-to-text + filler-word / disfluency detection.
# Get a key: https://www.assemblyai.com/app/account
ASSEMBLYAI_API_KEY=

# ElevenLabs (optional): realistic AI voice for the debate opponent.
# Without it, the app falls back to the free browser voice. Get a key: https://elevenlabs.io
ELEVENLABS_API_KEY=
# Optional: a voice id from your ElevenLabs account (defaults to a confident male voice).
ELEVENLABS_VOICE_ID=

# Stripe (optional): Premium subscriptions. Without these, everyone stays on Free.
# Use TEST keys first. Dashboard to Developers to API keys.
STRIPE_SECRET_KEY=
# The recurring Price id for SGD 10 / month (Products to your price).
STRIPE_PRICE_ID=
# Webhook signing secret (Developers to Webhooks to your endpoint).
STRIPE_WEBHOOK_SECRET=

# Supabase: database, auth, and storage.
# Dashboard to Project Settings to API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only admin key. Keep secret, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: base URL for SEO / Open Graph. Defaults to the production domain.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
